#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
        keymap {
                compatible = "zmk,keymap";

                default_layer {
// -----------------------------------------------------------------------------------------------------------
// |  TAB |  Q  |  W  |  E  |  R  |  T  |         | UP  |         |  Y  |  U  |  I  |  O  |  P  | BSPC |
// | CTRL |  A  |  S  |  D  |  F  |  G  |  | LEFT | ENT | RIGHT | |  H  |  J  |  K  |  L  |  ;  |  '   |
// | SHFT |  Z  |  X  |  C  |  V  |  B  | SPC |   | DOWN|         |  N  |  M  |  ,  |  .  |  /  | ESC  |
//                    | GUI | LWR | SPC |                          | ENT | RSE | ALT |
                        bindings = <
   &kp TAB   &kp Q &kp W &kp E &kp R &kp T              &kp UP                &kp Y &kp U  &kp I     &kp O   &kp P    &kp BSPC
   &kp LCTRL &kp A &kp S &kp D &kp F &kp G    &kp LEFT  &kp ENTER  &kp RIGHT  &kp H &kp J  &kp K     &kp L   &kp SEMI &kp SQT
   &kp LSHFT &kp Z &kp X &kp C &kp V &kp B  &kp SPACE   &kp DOWN              &kp N &kp M  &kp COMMA &kp DOT &kp FSLH &kp ESC
                  &kp LGUI &mo 1 &kp SPACE                                     &kp RET &mo 2 &kp RALT
                        >;
                };

                lower_layer {
// -----------------------------------------------------------------------------------------------------------
// |  TAB |  1  |  2  |  3  |  4  |  5  |         | UP  |         |  6  |  7  |  8  |  9  |  0  | BSPC |
// | BTCLR| BT1 | BT2 | BT3 | BT4 | BT5 |  | LEFT | ENT | RIGHT | | LFT | DWN |  UP | RGT |     |      |
// | SHFT |     |     |     |     |     | MUTE|   | DOWN|         |     |     |     |     |     |      |
//                    | GUI |     | SPC |                          | ENT |     | ALT |
                        bindings = <
   &kp TAB    &kp N1       &kp N2       &kp N3       &kp N4       &kp N5                    &trans              &kp N6   &kp N7   &kp N8 &kp N9    &kp N0 &kp BSPC
   &bt BT_CLR &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4  &trans    &trans    &trans    &kp LEFT &kp DOWN &kp UP &kp RIGHT &trans &trans
   &kp LSHFT  &trans       &trans       &trans       &trans       &trans      &kp C_MUTE    &trans              &trans   &trans   &trans &trans    &trans &trans
                                    &kp LGUI     &trans       &kp SPACE                                        &kp RET  &trans   &kp RALT
                        >;
                };

                raise_layer {
// -----------------------------------------------------------------------------------------------------------
// |  TAB |  !  |  @  |  #  |  $  |  %  |         | UP  |         |  ^  |  &  |  *  |  (  |  )  | BSPC |
// | CTRL |     |     |     |     |     |   | LEFT | ENT | RIGHT | |  -  |  =  |  [  |  ]  |  \  |  `   |
// | SHFT |     |     |     |     |     | MUTE|   | DOWN|         |  _  |  +  |  {  |  }  | "|" |  ~   |
//                    | GUI |     | SPC |                          | ENT |     | ALT |
                        bindings = <
   &kp  TAB  &kp EXCL &kp AT &kp HASH &kp DLLR &kp PRCNT                  &trans              &kp CARET &kp AMPS  &kp ASTRK &kp LPAR &kp RPAR &kp BSPC
   &kp LCTRL &trans   &trans &trans   &trans   &trans           &trans     &trans    &trans    &kp MINUS &kp EQUAL &kp LBKT  &kp RBKT &kp BSLH &kp GRAVE
   &kp LSHFT &trans   &trans &trans   &trans   &trans     &kp C_MUTE      &trans              &kp UNDER &kp PLUS  &kp LBRC  &kp RBRC &kp PIPE &kp TILDE
                             &kp LGUI &trans   &kp SPACE                                      &kp RET   &trans    &kp RALT
                        >;
                };
        };
};
